---
/* ─────────────────────────────────────────────────────────────
   AnchoredPopover — il dialog che resta dove serve.

   Pattern: popover non-modale ancorato al trigger.
   - Markup: nessun <dialog>. Un <div> con stato CSS via
     data-state="open|closed".
   - Posizionamento: CSS Anchor Positioning dove supportato
     (anchor-name + position-anchor); JS fallback con
     getBoundingClientRect per browser più vecchi.
   - Light dismiss: click fuori chiude commit; Esc annulla.
   - Focus trap "morbido": Tab dopo l'ultimo elemento esce e
     chiude — l'utente non resta intrappolato.
   ───────────────────────────────────────────────────────────── */
---

<div class="apop">
  <div class="apop__bar">
    <button
      class="apop__trigger"
      type="button"
      aria-expanded="false"
      aria-haspopup="dialog"
      aria-controls="apop-panel"
      data-anchor
    >
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M2 4h12M4 8h8M6 12h4"/>
      </svg>
      <span>Filtri</span>
      <span class="apop__count tabular" data-count>3</span>
    </button>

    <p class="apop__hint">Cliccando fuori si applicano i filtri; Esc annulla.</p>
  </div>

  <div
    class="apop__panel"
    id="apop-panel"
    role="dialog"
    aria-modal="false"
    aria-labelledby="apop-title"
    data-state="closed"
  >
    <h3 id="apop-title" class="apop__title">Filtra capitoli</h3>
    <ul class="apop__opts" role="list">
      <li><label class="apop__opt"><input type="checkbox" checked data-filter="motion" /> <span>Motion</span></label></li>
      <li><label class="apop__opt"><input type="checkbox" checked data-filter="typography" /> <span>Tipografia</span></label></li>
      <li><label class="apop__opt"><input type="checkbox" checked data-filter="accessibility" /> <span>Accessibilità</span></label></li>
      <li><label class="apop__opt"><input type="checkbox" data-filter="editorial" /> <span>Editoriale</span></label></li>
      <li><label class="apop__opt"><input type="checkbox" data-filter="experiments" /> <span>Esperimenti</span></label></li>
    </ul>
    <div class="apop__foot">
      <button class="apop__apply" type="button" data-action="apply">Applica</button>
    </div>
  </div>

  <p class="apop__live sr-only" aria-live="polite"></p>
</div>

<style>
  .apop {
    inline-size: min(28rem, 100%);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .apop__bar {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .apop__trigger {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    padding: 0.5rem 0.95rem;
    border-radius: var(--radius-pill);
    background-color: var(--surface-raised);
    border: 1px solid var(--border);
    color: var(--ink);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    cursor: pointer;
    transition:
      background-color var(--dur-fast) var(--ease-out-soft),
      border-color var(--dur-fast) var(--ease-out-soft);
    /* CSS Anchor Positioning — dove supportato */
    anchor-name: --apop-anchor;
  }
  .apop__trigger:hover { background-color: var(--surface); border-color: var(--border-strong); }
  .apop__trigger:focus-visible { outline: none; box-shadow: var(--halo-focus); }
  .apop__trigger[aria-expanded='true'] { border-color: var(--border-strong); background-color: var(--surface); }
  .apop__trigger svg { inline-size: 0.85rem; block-size: 0.85rem; color: var(--ink-muted); }

  .apop__count {
    padding: 0 0.4rem;
    min-inline-size: 1.1rem;
    block-size: 1.1rem;
    display: inline-grid;
    place-items: center;
    border-radius: var(--radius-pill);
    background-color: var(--accent-soft);
    color: var(--accent-ink);
    font-size: var(--text-2xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
  }

  .apop__hint {
    margin: 0;
    color: var(--ink-subtle);
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-wide);
  }

  /* Panel — posizionato in JS quando aperto. */
  .apop__panel {
    position: absolute;
    inset-block-start: 0;
    inset-inline-start: 0;
    inline-size: 16rem;
    padding: var(--space-sm);
    background-color: var(--surface-raised);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    opacity: 0;
    transform: scaleY(0.94);
    transform-origin: top center;
    pointer-events: none;
    transition:
      opacity var(--dur-fast) var(--ease-out-soft),
      transform var(--dur-fast) var(--ease-out-soft);
    z-index: var(--z-overlay);
    /* Anchor Positioning (progressive) */
    position-anchor: --apop-anchor;
  }
  /* Sui browser che supportano anchor positioning, posizioniamo qui.
     I valori sono comunque sovrascritti dal JS quando entriamo in JS-fallback. */
  @supports (position-anchor: --x) {
    .apop__panel {
      inset-block-start: anchor(bottom);
      inset-inline-start: anchor(start);
      margin-block-start: 0.4rem;
    }
  }

  .apop__panel[data-state='open'] {
    opacity: 1;
    transform: scaleY(1);
    pointer-events: auto;
  }

  .apop__title {
    margin: 0 0 0.15rem;
    color: var(--ink-subtle);
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
  }

  .apop__opts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .apop__opt {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
    padding: 0.35rem 0.45rem;
    border-radius: var(--radius-sm);
    color: var(--ink);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: background-color var(--dur-fast) var(--ease-out-soft);
  }
  .apop__opt:hover { background-color: var(--surface-sunken); }
  .apop__opt:focus-within { background-color: var(--surface-sunken); }
  .apop__opt input { accent-color: var(--accent); }

  .apop__foot {
    margin-block-start: 0.2rem;
    padding-block-start: 0.4rem;
    border-block-start: 1px solid var(--border);
    display: flex;
    justify-content: flex-end;
  }

  .apop__apply {
    padding: 0.4rem 0.85rem;
    border-radius: var(--radius-pill);
    background-color: var(--ink-strong);
    color: var(--bg);
    border: 0;
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    cursor: pointer;
  }
  .apop__apply:hover { opacity: 0.92; }
  .apop__apply:focus-visible { outline: none; box-shadow: var(--halo-focus); }

  .sr-only {
    position: absolute;
    inline-size: 1px; block-size: 1px;
    margin: -1px; padding: 0; border: 0;
    overflow: hidden; clip-path: inset(50%);
  }

  @media (prefers-reduced-motion: reduce) {
    .apop__panel { transition-duration: 1ms; transform: none; }
  }
</style>

<script>
  function bind() {
    document.querySelectorAll<HTMLElement>('.apop').forEach((root) => {
      if (root.dataset.bound === 'true') return;
      root.dataset.bound = 'true';

      const trigger = root.querySelector<HTMLButtonElement>('.apop__trigger')!;
      const panel = root.querySelector<HTMLElement>('.apop__panel')!;
      const applyBtn = root.querySelector<HTMLButtonElement>('[data-action="apply"]')!;
      const countEl = root.querySelector<HTMLElement>('[data-count]')!;
      const live = root.querySelector<HTMLElement>('.apop__live')!;
      const supportsAnchor = CSS.supports('position-anchor: --x');

      let previouslyFocused: HTMLElement | null = null;
      let snapshot: Record<string, boolean> = {};

      const checkboxes = panel.querySelectorAll<HTMLInputElement>('input[type="checkbox"]');

      const snap = () => {
        const s: Record<string, boolean> = {};
        checkboxes.forEach((c) => { s[c.dataset.filter!] = c.checked; });
        return s;
      };

      const restore = (s: Record<string, boolean>) => {
        checkboxes.forEach((c) => { c.checked = !!s[c.dataset.filter!]; });
      };

      const updateCount = () => {
        const n = Array.from(checkboxes).filter((c) => c.checked).length;
        countEl.textContent = String(n);
      };

      const position = () => {
        if (supportsAnchor) return; // CSS si occupa di tutto
        const r = trigger.getBoundingClientRect();
        const rootRect = root.getBoundingClientRect();
        panel.style.insetBlockStart = `${r.bottom - rootRect.top + 6}px`;
        panel.style.insetInlineStart = `${r.left - rootRect.left}px`;
      };

      const open = () => {
        snapshot = snap();
        previouslyFocused = document.activeElement as HTMLElement | null;
        panel.dataset.state = 'open';
        trigger.setAttribute('aria-expanded', 'true');
        position();
        // focus al primo checkbox
        requestAnimationFrame(() => {
          (checkboxes[0] ?? applyBtn).focus();
        });
      };

      const commit = () => {
        if (panel.dataset.state !== 'open') return;
        panel.dataset.state = 'closed';
        trigger.setAttribute('aria-expanded', 'false');
        updateCount();
        live.textContent = `Filtri applicati: ${countEl.textContent}`;
        previouslyFocused?.focus();
      };

      const cancel = () => {
        if (panel.dataset.state !== 'open') return;
        restore(snapshot);
        panel.dataset.state = 'closed';
        trigger.setAttribute('aria-expanded', 'false');
        live.textContent = 'Filtri ripristinati';
        previouslyFocused?.focus();
      };

      trigger.addEventListener('click', () => {
        if (panel.dataset.state === 'open') commit(); else open();
      });

      applyBtn.addEventListener('click', commit);

      // Esc → annulla
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && panel.dataset.state === 'open') {
          e.preventDefault();
          cancel();
        }
      });

      // Click fuori → commit
      document.addEventListener('click', (e) => {
        if (panel.dataset.state !== 'open') return;
        const target = e.target as Node;
        if (panel.contains(target) || trigger.contains(target)) return;
        commit();
      });

      // Focus trap MORBIDO — Tab dopo l'ultimo elemento esce e commit
      panel.addEventListener('keydown', (e) => {
        if (e.key !== 'Tab') return;
        const focusables = Array.from(
          panel.querySelectorAll<HTMLElement>('input, button, [tabindex]:not([tabindex="-1"])')
        );
        const first = focusables[0];
        const last = focusables[focusables.length - 1];
        if (!first || !last) return;
        if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          commit();
        }
        // Shift+Tab dal primo: lasciamo che esca naturalmente (l'utente
        // sta tornando indietro) — il click-fuori-handler farà commit.
      });

      // Riposiziona su resize (solo fallback JS)
      window.addEventListener('resize', () => {
        if (panel.dataset.state === 'open') position();
      });

      updateCount();
    });
  }

  document.addEventListener('astro:page-load', bind);
</script>
