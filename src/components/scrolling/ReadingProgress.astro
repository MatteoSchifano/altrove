---
/* ─────────────────────────────────────────────────────────────
   ReadingProgress — la barra che dice "sei a questo punto".

   Pattern: scroll-driven animation via `animation-timeline:
   scroll(self)` su un contenitore con overflow. Niente JS per
   browser moderni. Fallback: stessa scena, barra ferma — non si
   nota, non si rompe.

   Confina lo scroll alla stage del Demo (overflow auto su una
   colonna fissa), così il lettore può "leggere" l'articolo
   finto senza muovere la pagina vera.
   ───────────────────────────────────────────────────────────── */
---

<div class="rp">
  <div class="rp__chrome" aria-hidden="true">
    <span class="rp__title">Un capitolo breve</span>
    <span class="rp__pct tabular" data-pct>0%</span>
  </div>
  <div class="rp__bar" aria-hidden="true">
    <div class="rp__fill"></div>
  </div>

  <div class="rp__scroller" data-scroller tabindex="0" aria-label="Articolo di prova scrollabile">
    <article class="rp__article">
      <h2>Una piccola finestra</h2>
      <p>Le interfacce che chiedono concentrazione devono restituire fiducia. Una barra di lettura sottile, ferma in alto, è un patto silenzioso: ti dico dove sei e quanto manca, senza distrarti.</p>
      <p>Il movimento di questa barra è guidato dallo scroll della finestra qui sotto, non dal tempo: se ti fermi, lei si ferma; se torni indietro, lei torna indietro. È un indicatore di posizione, non un'animazione.</p>
      <p>Il valore percentuale a destra usa cifre tabulari — così quando passa da 9 a 10 non sussulta. La precisione tipografica non è vanità: è la condizione per cui un numero "vivo" non diventa fastidio.</p>
      <h3>Cosa la barra non fa</h3>
      <p>Non lampeggia. Non si gonfia all'arrivo. Non celebra il 100% con un fuoco d'artificio. Arrivare in fondo a una lettura è un gesto privato: la barra si conclude e basta.</p>
      <p>Su <code>prefers-reduced-motion: reduce</code> non cambia nulla — non c'è motion qui, c'è solo mappatura. La differenza è importante: ridurre il movimento non significa togliere informazione.</p>
      <h3>Il fallback gentile</h3>
      <p>Nei browser che non supportano <code>animation-timeline: scroll()</code> la barra resta a zero. Un piccolo script di sicurezza la spinge col <code>scroll</code> event passivo, così il valore arriva comunque — ma la versione nativa, quando c'è, è di gran lunga preferita: gira sul compositor, mai sul main thread.</p>
      <p>Continua a scorrere. Quasi finito.</p>
      <p>L'ultimo paragrafo è il momento più delicato di una lettura lunga: chi è arrivato qui ha deciso di starci. Tutto quello che si guadagna in fondo, si guadagna con la pazienza dei primi due terzi.</p>
    </article>
  </div>
</div>

<style>
  .rp {
    inline-size: min(32rem, 100%);
    border-radius: var(--radius-lg);
    background-color: var(--surface-raised);
    border: 1px solid var(--border);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .rp__chrome {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-2xs) var(--space-md);
    border-block-end: 1px solid var(--border);
    background-color: var(--surface);
  }
  .rp__title {
    color: var(--ink);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-snug);
  }
  .rp__pct {
    color: var(--ink-subtle);
    font-size: var(--text-2xs);
    font-family: var(--font-mono);
  }

  .rp__bar {
    block-size: 3px;
    background-color: var(--surface-sunken);
    position: relative;
    overflow: hidden;
  }
  .rp__fill {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      var(--accent),
      color-mix(in oklab, var(--accent), var(--accent-ink) 30%)
    );
    transform-origin: left center;
    transform: scaleX(0);
    will-change: transform;
  }

  .rp__scroller {
    block-size: 22rem;
    overflow-y: auto;
    padding: var(--space-md) var(--space-lg);
    scroll-behavior: smooth;
    overscroll-behavior: contain;
  }
  .rp__scroller:focus-visible {
    outline: none;
    box-shadow: inset 0 0 0 2px var(--accent);
  }

  /* Scroll-driven nativo: la barra si riempie con lo scroll dello scroller */
  @supports (animation-timeline: scroll()) {
    .rp__scroller { scroll-timeline-name: --rp-scroll; }
    .rp__fill {
      animation: rp-progress linear forwards;
      animation-timeline: --rp-scroll;
    }
    @keyframes rp-progress {
      to { transform: scaleX(1); }
    }
  }

  .rp__article {
    color: var(--ink);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    max-inline-size: 38ch;
  }
  .rp__article :global(h2) {
    margin: 0 0 var(--space-2xs);
    font-size: var(--text-md);
    color: var(--ink-strong);
    letter-spacing: var(--tracking-snug);
    font-weight: var(--weight-medium);
  }
  .rp__article :global(h3) {
    margin: var(--space-md) 0 var(--space-2xs);
    font-size: var(--text-sm);
    color: var(--ink-strong);
    letter-spacing: var(--tracking-snug);
    font-weight: var(--weight-medium);
  }
  .rp__article :global(p) {
    margin: 0 0 var(--space-sm);
  }
  .rp__article :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background-color: var(--surface-sunken);
    padding: 0.05em 0.35em;
    border-radius: var(--radius-xs);
  }
</style>

<script>
  /* Fallback per browser senza animation-timeline + aggiornamento percentuale.
     Aggiornamento percentuale comunque utile: il numero non è animato dal CSS. */
  function bind() {
    document.querySelectorAll<HTMLElement>('.rp').forEach((el) => {
      if (el.dataset.bound === 'true') return;
      el.dataset.bound = 'true';

      const scroller = el.querySelector<HTMLElement>('[data-scroller]')!;
      const pct = el.querySelector<HTMLElement>('[data-pct]')!;
      const fill = el.querySelector<HTMLElement>('.rp__fill')!;

      const supportsST = CSS.supports?.('animation-timeline: scroll()') ?? false;

      const update = () => {
        const max = scroller.scrollHeight - scroller.clientHeight;
        const ratio = max <= 0 ? 0 : Math.min(1, Math.max(0, scroller.scrollTop / max));
        pct.textContent = `${Math.round(ratio * 100)}%`;
        if (!supportsST) {
          fill.style.transform = `scaleX(${ratio})`;
        }
      };

      scroller.addEventListener('scroll', update, { passive: true });
      update();
    });
  }

  document.addEventListener('astro:page-load', bind);
</script>
