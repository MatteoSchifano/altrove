---
/* ─────────────────────────────────────────────────────────────
   ThemeToggle — un pulsante a tre stati (system → light → dark
   → system). La preferenza è salvata in localStorage, applicata
   via [data-theme] su <html>. La transizione visiva è gestita
   da global.css, qui pensiamo solo allo stato.
   ───────────────────────────────────────────────────────────── */
---

<button
  type="button"
  class="theme-toggle"
  data-motion="lift"
  data-distance="-2"
  data-scale="1.04"
  data-preset="snappy"
  aria-label="Cambia tema"
  data-theme-toggle
>
  {/* Tre icone sovrapposte; la classe attiva determina quale è visibile */}
  <span class="theme-toggle__icon" data-icon="system" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="4" width="18" height="14" rx="2" />
      <path d="M8 21h8M12 17v4" />
    </svg>
  </span>
  <span class="theme-toggle__icon" data-icon="light" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="4" />
      <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
    </svg>
  </span>
  <span class="theme-toggle__icon" data-icon="dark" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
    </svg>
  </span>
  <span class="sr-only" data-theme-label>Tema sistema</span>
</button>

<style>
  .theme-toggle {
    --size: 2.5rem;
    position: relative;
    inline-size: var(--size);
    block-size: var(--size);
    display: inline-grid;
    place-items: center;
    border-radius: var(--radius-pill);
    color: var(--ink-muted);
    background-color: var(--surface);
    border: 1px solid var(--border);
    transition:
      color var(--dur-fast) var(--ease-out-soft),
      background-color var(--dur-fast) var(--ease-out-soft),
      border-color var(--dur-fast) var(--ease-out-soft);
  }

  .theme-toggle:hover {
    color: var(--ink-strong);
    background-color: var(--surface-raised);
    border-color: var(--border-strong);
  }

  .theme-toggle__icon {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    opacity: 0;
    transform: scale(0.6) rotate(-30deg);
    transition:
      opacity var(--dur-fast) var(--ease-out-soft),
      transform var(--dur-normal) var(--ease-out-snug);
  }

  .theme-toggle__icon svg {
    inline-size: 1.125rem;
    block-size: 1.125rem;
  }

  /* Mostra l'icona giusta in base allo stato corrente del documento */
  :root:not([data-theme]) .theme-toggle__icon[data-icon='system'],
  :root[data-theme='light'] .theme-toggle__icon[data-icon='light'],
  :root[data-theme='dark']  .theme-toggle__icon[data-icon='dark'] {
    opacity: 1;
    transform: scale(1) rotate(0);
  }
</style>

<script>
  type ThemeMode = 'system' | 'light' | 'dark';
  const NEXT: Record<ThemeMode, ThemeMode> = {
    system: 'light',
    light: 'dark',
    dark: 'system',
  };
  const LABEL: Record<ThemeMode, string> = {
    system: 'Tema sistema',
    light: 'Tema chiaro',
    dark: 'Tema scuro',
  };

  function currentMode(): ThemeMode {
    const t = document.documentElement.dataset.theme;
    return t === 'light' || t === 'dark' ? t : 'system';
  }

  function applyMode(mode: ThemeMode) {
    if (mode === 'system') {
      delete document.documentElement.dataset.theme;
      try { localStorage.removeItem('altrove-theme'); } catch {}
    } else {
      document.documentElement.dataset.theme = mode;
      try { localStorage.setItem('altrove-theme', mode); } catch {}
    }
    document.querySelectorAll<HTMLElement>('[data-theme-label]').forEach((el) => {
      el.textContent = LABEL[mode];
    });
  }

  function bind() {
    document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach((btn) => {
      // Sincronizza la label all'init
      const label = btn.querySelector<HTMLElement>('[data-theme-label]');
      if (label) label.textContent = LABEL[currentMode()];

      // Idempotente: se già bound, salta
      if (btn.dataset.themeBound === 'true') return;
      btn.dataset.themeBound = 'true';

      btn.addEventListener('click', () => {
        applyMode(NEXT[currentMode()]);
      });
    });
  }

  document.addEventListener('astro:page-load', bind);
</script>
