---
/* ─────────────────────────────────────────────────────────────
   RoadmapSection — il cammino del libro, a serpentina.

   Cosa cambia rispetto a una timeline dritta: il "filo" diventa
   un percorso SVG che zigzaga fra due colonne. I capitoli si
   alternano a sinistra e a destra del percorso, come fermate
   lungo una strada che curva. Le fasi (A · B · C · D) sono
   "tappe" del viaggio — header full-width che spezzano il ritmo.

   Tre meccanismi di scroll, tutti dal vocabolario del cap. 05:
   1. Drawing del percorso (stroke-dashoffset via animation-
      timeline: view() + fallback JS in passive scroll).
   2. Reveal a passo singolo di ogni capitolo (IntersectionObserver,
      unobserve dopo trigger). L'apparizione è sincronizzata col
      passaggio del filo: il capitolo entra quando il filo "tocca"
      il suo nodo.
   3. Nodo che si "accende" quando il filo lo raggiunge (CSS
      transition triggered dal data-revealed).

   Allineamento HTML/SVG: il container ha grid-template-rows con
   altezze fisse (entry = 9rem, phase header = 5rem), così le
   coordinate Y dei nodi SVG corrispondono esattamente alle Y
   delle entry HTML.

   Su mobile (<= 39rem) il layout collassa a una colonna; il
   percorso serpentino non avrebbe spazio per respirare, quindi
   diventa una linea verticale semplice a sinistra.
   ───────────────────────────────────────────────────────────── */

import {
  ROADMAP,
  PHASE_LABEL,
  mergeWithCollection,
  type Phase,
  type MergedRoadmapEntry,
} from '../lib/roadmap';
import { t, type Locale } from '../lib/i18n';
import type { CollectionEntry } from 'astro:content';

interface Props {
  locale: Locale;
  publishedChapters: ReadonlyArray<CollectionEntry<'chapters'>>;
}
const { locale, publishedChapters } = Astro.props;

const entries = mergeWithCollection(publishedChapters, locale);

/* ── Geometria ────────────────────────────────────────────── */
/* Tutte in `rem` × 16 (= px), così combaciano col CSS sotto. */
const REM = 16;
const ENTRY_H = 9 * REM;   // 144 — block-size di ogni entry
const PHASE_H = 5 * REM;   // 80  — block-size di ogni phase header
const W = 400;              // larghezza nominale del viewBox
const X_LEFT = 64;
const X_RIGHT = W - X_LEFT;

/* Costruisco i nodi (uno per capitolo) con la loro coordinata Y
   calcolata sommando phase header e entry precedenti. */
interface PathNode {
  globalIndex: number;
  entry: MergedRoadmapEntry;
  side: 'L' | 'R';
  x: number;
  y: number;
}

const PHASES: readonly Phase[] = ['A', 'B', 'C', 'D'] as const;
const phaseStartIndex: Record<Phase, number> = { A: -1, B: -1, C: -1, D: -1 };

let cursorY = 0;
let currentPhase: Phase | null = null;
const nodes: PathNode[] = [];

entries.forEach((e, i) => {
  if (e.phase !== currentPhase) {
    cursorY += PHASE_H;
    phaseStartIndex[e.phase] = nodes.length;
    currentPhase = e.phase;
  }
  const side: 'L' | 'R' = i % 2 === 0 ? 'L' : 'R';
  const x = side === 'L' ? X_LEFT : X_RIGHT;
  const y = cursorY + ENTRY_H / 2;
  nodes.push({ globalIndex: i, entry: e, side, x, y });
  cursorY += ENTRY_H;
});

const TOTAL_H = cursorY;

/* Path SVG: M sul primo nodo, poi una cubica per ogni segmento.
   I control point sono sopra/sotto il punto, allineati X, così
   la curva è una S morbida senza picchi.

   Esempio segmento i-1 → i:
     prev = (x0, y0), curr = (x1, y1), midY = (y0+y1)/2
     C x0 midY, x1 midY, x1 y1
*/
function buildPath(ns: PathNode[]): string {
  if (ns.length === 0) return '';
  let d = `M ${ns[0]!.x} ${ns[0]!.y}`;
  for (let i = 1; i < ns.length; i++) {
    const prev = ns[i - 1]!;
    const curr = ns[i]!;
    const midY = (prev.y + curr.y) / 2;
    d += ` C ${prev.x} ${midY}, ${curr.x} ${midY}, ${curr.x} ${curr.y}`;
  }
  return d;
}
const pathD = buildPath(nodes);

/* Raggruppo le entry per fase, mantenendo l'indice globale. */
const byPhase = new Map<Phase, PathNode[]>();
for (const ph of PHASES) byPhase.set(ph, []);
for (const n of nodes) byPhase.get(n.entry.phase)!.push(n);
---

<section class="roadmap" aria-labelledby="roadmap-title">
  <div class="container">
    <header class="roadmap__head">
      <h2 id="roadmap-title" class="roadmap__title">{t('home.roadmapTitle', locale)}</h2>
      <p class="roadmap__lede">{t('home.roadmapLede', locale)}</p>
    </header>

    <div class="roadmap__body" data-roadmap style={`--total-h: ${TOTAL_H}px;`}>
      <!-- Percorso serpentino (decorazione di fondo) -->
      <svg
        class="roadmap__svg"
        viewBox={`0 0 ${W} ${TOTAL_H}`}
        preserveAspectRatio="none"
        aria-hidden="true"
      >
        <!-- Linea base (sempre visibile, ink-subtle) -->
        <path
          class="roadmap__line roadmap__line--base"
          d={pathD}
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          vector-effect="non-scaling-stroke"
        />
        <!-- Linea attiva (si disegna con lo scroll) -->
        <path
          class="roadmap__line roadmap__line--active"
          d={pathD}
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          pathLength="1000"
          vector-effect="non-scaling-stroke"
          data-line
        />
        <!-- Nodi -->
        {nodes.map((n) => (
          <g class={`roadmap__node roadmap__node--${n.entry.status}`} data-node-index={n.globalIndex}>
            <circle class="roadmap__node-outer" cx={n.x} cy={n.y} r="9" vector-effect="non-scaling-stroke" />
            <circle class="roadmap__node-inner" cx={n.x} cy={n.y} r="4" />
          </g>
        ))}
      </svg>

      <!-- Lista capitoli alternati intorno al percorso -->
      <ol class="roadmap__list">
        {PHASES.map((phase) => {
          const list = byPhase.get(phase)!;
          if (list.length === 0) return null;
          return (
            <li class="phase">
              <h3 class="phase__head">
                <span class="phase__letter tabular">{phase}</span>
                <span class="phase__label">{PHASE_LABEL[phase][locale]}</span>
              </h3>
              <ul role="list" class="phase__entries">
                {list.map((n, localI) => {
                  const e = n.entry;
                  const isLink = e.status === 'published' && e.href;
                  const ariaCurrent = e.status === 'next' ? 'step' : undefined;
                  return (
                    <li
                      class={`entry entry--${n.side.toLowerCase()}`}
                      data-status={e.status}
                      data-index={n.globalIndex}
                      style={`--i:${localI}`}
                      aria-current={ariaCurrent}
                    >
                      <span class="entry__num tabular" aria-hidden="true">{e.number}</span>
                      {isLink ? (
                        <a class="entry__body" href={e.href!}>
                          <h4 class="entry__title">{e.title[locale]}</h4>
                          <p class="entry__question">{e.question[locale]}</p>
                        </a>
                      ) : (
                        <div class="entry__body">
                          <h4 class="entry__title">
                            {e.title[locale]}
                            {e.status === 'next' && (
                              <span class="entry__kicker">{t('roadmap.statusNext', locale)}</span>
                            )}
                          </h4>
                          <p class="entry__question">{e.question[locale]}</p>
                          {e.effort && (
                            <span class="entry__effort tabular" aria-hidden="true">
                              {'·'.repeat(e.effort)}
                            </span>
                          )}
                          <span class="sr-only">
                            {e.status === 'planned'
                              ? t('roadmap.statusPlanned', locale)
                              : t('roadmap.statusNext', locale)}
                          </span>
                        </div>
                      )}
                    </li>
                  );
                })}
              </ul>
            </li>
          );
        })}
      </ol>
    </div>
  </div>
</section>

<style>
  .roadmap {
    padding-block: var(--rhythm) var(--rhythm-loose);
    border-block-start: 1px solid var(--border);
  }

  /* ─── Head ───────────────────────────────────────────────── */
  .roadmap__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
    margin-block-end: var(--space-xl);
    padding-block-end: var(--space-md);
    border-block-end: 1px solid var(--border);
    flex-wrap: wrap;
  }
  .roadmap__title {
    font-size: var(--text-md);
    color: var(--ink-muted);
    font-weight: var(--weight-medium);
    margin: 0;
  }
  .roadmap__lede {
    margin: 0;
    color: var(--ink-subtle);
    font-size: var(--text-xs);
    font-style: italic;
  }

  /* ─── Body — contenitore col percorso ──────────────────── */
  .roadmap__body {
    position: relative;
    /* L'altezza è imposta dalla geometria HTML; il SVG si adatta. */
  }

  .roadmap__svg {
    position: absolute;
    inset: 0;
    inline-size: 100%;
    block-size: 100%;
    pointer-events: none;
    z-index: 0;
    overflow: visible; /* nodi a r=9 possono sporgere dal viewBox */
  }

  /* Linea base — sempre visibile, in ink-subtle */
  .roadmap__line--base {
    color: var(--border);
  }
  /* Linea attiva — si disegna con lo scroll, in accent */
  .roadmap__line--active {
    color: var(--accent);
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
  }

  @supports (animation-timeline: view()) {
    .roadmap__body { view-timeline-name: --roadmap-progress; }
    .roadmap__line--active {
      animation: roadmap-draw linear forwards;
      animation-timeline: --roadmap-progress;
      animation-range: cover 0% cover 95%;
    }
    @keyframes roadmap-draw {
      to { stroke-dashoffset: 0; }
    }
  }

  /* ─── Nodi del percorso ────────────────────────────────── */
  .roadmap__node-outer {
    fill: var(--bg);
    stroke: currentColor;
    stroke-width: 1.5;
    transition:
      stroke-width var(--dur-normal) var(--ease-out-snug),
      transform var(--dur-normal) var(--ease-out-snug);
    transform-origin: center;
    transform-box: fill-box;
  }
  .roadmap__node-inner {
    fill: transparent;
    transition: fill var(--dur-normal) var(--ease-out-snug),
                transform var(--dur-normal) var(--ease-out-snug);
    transform-origin: center;
    transform-box: fill-box;
  }

  .roadmap__node--published { color: var(--accent); }
  .roadmap__node--published .roadmap__node-inner { fill: var(--accent); }

  .roadmap__node--next { color: var(--accent); }
  .roadmap__node--next .roadmap__node-outer {
    stroke-width: 2;
    /* anello pulsante: opacità ciclica per richiamare attenzione */
    animation: node-pulse 2400ms var(--ease-in-out) infinite;
  }
  @keyframes node-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.55; transform: scale(1.15); }
  }

  .roadmap__node--planned { color: var(--border-strong); }
  .roadmap__node--planned .roadmap__node-outer { stroke-dasharray: 2 2; }

  /* ─── Lista capitoli ────────────────────────────────────── */
  .roadmap__list {
    position: relative;
    z-index: 1;
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
  }

  .phase {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: var(--space-2xl);
    row-gap: 0;
  }

  /* ─── Phase header — full-width, sopra il path ─────────── */
  .phase__head {
    grid-column: 1 / -1;
    block-size: 5rem; /* deve combaciare con PHASE_H sopra */
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    color: var(--ink-muted);
    /* sfondo che "spezza" visivamente il path che vi passa dietro */
    background:
      radial-gradient(
        ellipse at center,
        var(--bg) 0%,
        var(--bg) 60%,
        transparent 100%
      );
    text-align: center;
  }
  .phase__letter {
    font-family: var(--font-mono);
    font-size: var(--text-md);
    color: var(--ink-strong);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
    padding: 0.25rem 0.65rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border);
    background-color: var(--surface);
    line-height: 1;
  }
  .phase__label {
    font-size: var(--text-xs);
    color: var(--ink-muted);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
  }

  /* ─── Entries ───────────────────────────────────────────── */
  .phase__entries {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: var(--space-2xl);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .entry {
    block-size: 9rem; /* deve combaciare con ENTRY_H sopra */
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: var(--space-2xs);
    padding-inline: var(--space-md);

    opacity: 0;
    transform: translateY(8px);
    will-change: opacity, transform;
  }
  .entry--l {
    grid-column: 1;
    justify-self: end;
    text-align: end;
    grid-template-columns: 1fr auto;
    transform: translate(-8px, 8px);
  }
  .entry--r {
    grid-column: 2;
    justify-self: start;
    transform: translate(8px, 8px);
  }

  .entry[data-revealed='true'] {
    opacity: 1;
    transform: translate(0, 0);
    transition:
      opacity 520ms var(--ease-out-soft) calc(var(--i, 0) * 30ms),
      transform 560ms var(--ease-out-snug) calc(var(--i, 0) * 30ms);
  }

  /* Numero capitolo — sempre verso il percorso (lato interno) */
  .entry__num {
    font-family: var(--font-mono);
    font-size: var(--text-md);
    color: var(--ink-subtle);
    letter-spacing: var(--tracking-wide);
    line-height: 1;
    align-self: center;
  }
  .entry--l .entry__num { grid-column: 2; }
  .entry--r .entry__num { grid-column: 1; }

  /* Body */
  .entry__body {
    display: grid;
    gap: var(--space-3xs);
    text-decoration: none;
    color: inherit;
    padding: var(--space-2xs) var(--space-sm);
    border-radius: var(--radius-md);
    background-color: color-mix(in oklab, var(--bg) 88%, transparent);
    border: 1px solid transparent;
    transition:
      transform var(--dur-fast) var(--ease-out-soft),
      border-color var(--dur-fast) var(--ease-out-soft),
      background-color var(--dur-fast) var(--ease-out-soft);
  }
  .entry--l .entry__body { grid-column: 1; }
  .entry--r .entry__body { grid-column: 2; }

  a.entry__body:hover {
    border-color: var(--border);
    background-color: var(--surface-raised);
  }
  a.entry__body:focus-visible {
    outline: none;
    box-shadow: var(--halo-focus);
    border-color: var(--accent);
  }
  a.entry__body:hover .entry__title { color: var(--accent-ink); }

  .entry__title {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-snug);
    font-weight: var(--weight-medium);
    color: var(--ink-strong);
    transition: color var(--dur-fast) var(--ease-out-soft);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2xs);
  }
  .entry--l .entry__title { justify-content: flex-end; }
  .entry__question {
    margin: 0;
    font-size: var(--text-xs);
    line-height: var(--leading-relaxed);
    color: var(--ink-muted);
    max-inline-size: 30ch;
  }
  .entry--l .entry__question { margin-inline-start: auto; }

  /* Stati */
  [data-status='next'] .entry__kicker {
    font-size: var(--text-2xs);
    color: var(--accent-ink);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    padding-inline: 0.45rem;
    padding-block: 0.05rem;
    border-radius: var(--radius-pill);
    background-color: color-mix(in oklab, var(--accent) 14%, transparent);
  }
  [data-status='planned'] .entry__title {
    color: var(--ink-muted);
    font-weight: var(--weight-regular);
  }
  [data-status='planned'] .entry__question { color: var(--ink-subtle); }

  .entry__effort {
    color: var(--ink-subtle);
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    opacity: 0.6;
    letter-spacing: 0.15em;
  }
  .entry--l .entry__effort { text-align: end; }

  /* ─── sr-only ────────────────────────────────────────────── */
  .sr-only {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ─── Mobile fallback: una colonna, niente serpentina ─── */
  @media (max-width: 39rem) {
    .roadmap__svg { display: none; }

    .phase {
      grid-template-columns: 1fr;
    }
    .phase__entries {
      grid-template-columns: 1fr;
      border-inline-start: 2px solid var(--border);
      padding-inline-start: var(--space-lg);
      margin-inline-start: var(--space-2xs);
    }
    .entry {
      block-size: auto;
      min-block-size: 7rem;
      padding-block: var(--space-sm);
    }
    .entry--l, .entry--r {
      grid-column: 1;
      grid-template-columns: auto 1fr;
      justify-self: stretch;
      text-align: start;
      transform: translateY(8px); /* per il reveal */
    }
    .entry--l .entry__num,
    .entry--r .entry__num { grid-column: 1; }
    .entry--l .entry__body,
    .entry--r .entry__body { grid-column: 2; }
    .entry--l .entry__title { justify-content: flex-start; }
    .entry--l .entry__question { margin-inline-start: 0; }
    .entry--l .entry__effort { text-align: start; }

    .phase__head {
      block-size: auto;
      padding-block: var(--space-md);
      justify-content: flex-start;
      background: none;
    }
  }

  /* ─── Reduced motion ────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .entry,
    .entry[data-revealed='true'] {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .roadmap__line--active {
      animation: none !important;
      stroke-dashoffset: 0;
    }
    .roadmap__node--next .roadmap__node-outer { animation: none; }
    .roadmap__node-outer,
    .roadmap__node-inner,
    a.entry__body,
    .entry__title { transition: none; }
  }
</style>

<script>
  /* Bind idempotente, stesso pattern di src/components/scrolling/*.

     - Reveal a passo singolo via IntersectionObserver (unobserve dopo trigger).
       Ogni entry rivela il proprio nodo SVG corrispondente: il piccolo "ping"
       del nodo è coordinato col fade-in del corpo.

     - Fallback drawing: se il browser non supporta animation-timeline: view(),
       calcoliamo il progresso dello scroll della sezione e aggiorniamo
       stroke-dashoffset in passive scroll (1000 → 0). */
  function bind() {
    document.querySelectorAll<HTMLElement>('.roadmap').forEach((root) => {
      if (root.dataset.bound === 'true') return;
      root.dataset.bound = 'true';

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      /* ── Reveal entries + accensione dei nodi corrispondenti ── */
      const entries = root.querySelectorAll<HTMLElement>('.entry');
      const nodeByIndex = new Map<number, HTMLElement>();
      root.querySelectorAll<HTMLElement>('.roadmap__node').forEach((n) => {
        const idx = Number(n.dataset.nodeIndex);
        if (Number.isFinite(idx)) nodeByIndex.set(idx, n);
      });

      if (reduced) {
        entries.forEach((el) => (el.dataset.revealed = 'true'));
        nodeByIndex.forEach((n) => (n.dataset.revealed = 'true'));
      } else {
        const obs = new IntersectionObserver(
          (records) => {
            records.forEach((rec) => {
              if (rec.isIntersecting && rec.target instanceof HTMLElement) {
                const el = rec.target;
                el.dataset.revealed = 'true';
                const idx = Number(el.dataset.index);
                const node = nodeByIndex.get(idx);
                if (node) node.dataset.revealed = 'true';
                obs.unobserve(el);
              }
            });
          },
          { threshold: 0.35 },
        );
        entries.forEach((el) => obs.observe(el));
      }

      /* ── Fallback drawing del percorso ── */
      const supportsTL =
        CSS.supports?.('animation-timeline: view()') ?? false;
      if (!supportsTL && !reduced) {
        const body = root.querySelector<HTMLElement>('[data-roadmap]');
        const line = root.querySelector<SVGPathElement>('[data-line]');
        if (body && line) {
          let ticking = false;
          const update = () => {
            const rect = body.getBoundingClientRect();
            const vh = window.innerHeight || document.documentElement.clientHeight;
            const total = rect.height + vh;
            const progressed = vh - rect.top;
            const ratio = Math.min(1, Math.max(0, progressed / total));
            const offset = 1000 * (1 - ratio);
            line.style.strokeDashoffset = String(offset);
            ticking = false;
          };
          const onScroll = () => {
            if (!ticking) {
              window.requestAnimationFrame(update);
              ticking = true;
            }
          };
          window.addEventListener('scroll', onScroll, { passive: true });
          window.addEventListener('resize', onScroll, { passive: true });
          update();
        }
      }
    });
  }

  document.addEventListener('astro:page-load', bind);
</script>
