---
/* ─────────────────────────────────────────────────────────────
   RoadmapSection — il cammino del libro.

   Una linea verticale centrale che cresce con lo scroll. I capitoli
   si alternano a sinistra e a destra della linea, come fermate
   lungo una strada dritta. I nodi (cerchi piccoli) sono posizionati
   sulla linea, uno per capitolo. Le fasi (A · B · C · D) sono
   "tappe" del viaggio — header full-width che spezzano il ritmo.

   Tre meccanismi di scroll:
   1. Crescita della linea attiva (transform: scaleY via animation-
      timeline: view() con `entry 50% exit 50%` → sync 1:1 col centro
      della viewport. Fallback JS in passive scroll calcola lo stesso
      ratio.).
   2. Reveal a passo singolo di ogni capitolo (IntersectionObserver,
      unobserve dopo trigger).
   3. Nodo che si "accende" quando entry corrispondente è rivelata
      (CSS transition triggered dal data-revealed).

   Su mobile (<= 39rem) il layout collassa a una colonna; la linea
   centrale e i nodi vengono nascosti, le entries diventano lista
   semplice con un border-left sottile come traccia visiva.
   ───────────────────────────────────────────────────────────── */

import {
  ROADMAP,
  PHASE_LABEL,
  mergeWithCollection,
  type Phase,
  type MergedRoadmapEntry,
} from '../lib/roadmap';
import { t, type Locale } from '../lib/i18n';
import type { CollectionEntry } from 'astro:content';

interface Props {
  locale: Locale;
  publishedChapters: ReadonlyArray<CollectionEntry<'chapters'>>;
}
const { locale, publishedChapters } = Astro.props;

const entries = mergeWithCollection(publishedChapters, locale);

/* ── Geometria ────────────────────────────────────────────── */
/* Tutte in `rem` × 16 (= px), così combaciano col CSS sotto.
   Linea retta centrale: tutti i nodi stanno a left:50%, l'unica
   coordinata che varia per nodo è la Y. */
const REM = 16;
const ENTRY_H = 9 * REM;   // 144 — block-size di ogni entry
const PHASE_H = 5 * REM;   // 80  — block-size di ogni phase header

interface PathNode {
  globalIndex: number;
  entry: MergedRoadmapEntry;
  side: 'L' | 'R';  // serve solo al layout zigzag delle entries (left/right)
  y: number;
}

const PHASES: readonly Phase[] = ['A', 'B', 'C', 'D'] as const;

let cursorY = 0;
let currentPhase: Phase | null = null;
const nodes: PathNode[] = [];

entries.forEach((e, i) => {
  if (e.phase !== currentPhase) {
    cursorY += PHASE_H;
    currentPhase = e.phase;
  }
  const side: 'L' | 'R' = i % 2 === 0 ? 'L' : 'R';
  const y = cursorY + ENTRY_H / 2;
  nodes.push({ globalIndex: i, entry: e, side, y });
  cursorY += ENTRY_H;
});

const TOTAL_H = cursorY;

/* Raggruppo le entry per fase, mantenendo l'indice globale. */
const byPhase = new Map<Phase, PathNode[]>();
for (const ph of PHASES) byPhase.set(ph, []);
for (const n of nodes) byPhase.get(n.entry.phase)!.push(n);
---

<section class="roadmap" aria-labelledby="roadmap-title">
  <div class="container">
    <header class="roadmap__head">
      <h2 id="roadmap-title" class="roadmap__title">{t('home.roadmapTitle', locale)}</h2>
      <p class="roadmap__lede">{t('home.roadmapLede', locale)}</p>
    </header>

    <div class="roadmap__body" data-roadmap style={`--total-h: ${TOTAL_H}px;`}>
      <!-- Linea verticale centrale (decorazione di fondo). Due div sovrapposti:
           base sempre visibile, attiva che cresce con lo scroll. -->
      <div class="roadmap__line roadmap__line--base" aria-hidden="true" />
      <div class="roadmap__line roadmap__line--active" aria-hidden="true" data-line />

      <!-- Nodi (HTML, posizionati assolutamente sulla linea centrale). -->
      {nodes.map((n) => (
        <span
          class={`roadmap__node roadmap__node--${n.entry.status}`}
          data-node-index={n.globalIndex}
          aria-hidden="true"
          style={`top: ${n.y}px;`}
        />
      ))}

      <!-- Lista capitoli alternati intorno al percorso -->
      <ol class="roadmap__list">
        {PHASES.map((phase) => {
          const list = byPhase.get(phase)!;
          if (list.length === 0) return null;
          return (
            <li class="phase">
              <h3 class="phase__head">
                <span class="phase__letter tabular">{phase}</span>
                <span class="phase__label">{PHASE_LABEL[phase][locale]}</span>
              </h3>
              <ul role="list" class="phase__entries">
                {list.map((n, localI) => {
                  const e = n.entry;
                  const isLink = e.status === 'published' && e.href;
                  const ariaCurrent = e.status === 'next' ? 'step' : undefined;
                  return (
                    <li
                      class={`entry entry--${n.side.toLowerCase()}`}
                      data-status={e.status}
                      data-index={n.globalIndex}
                      style={`--i:${localI}; grid-row: ${localI + 1};`}
                      aria-current={ariaCurrent}
                    >
                      <span class="entry__num tabular" aria-hidden="true">{e.number}</span>
                      {isLink ? (
                        <a class="entry__body" href={e.href!}>
                          <h4 class="entry__title">{e.title[locale]}</h4>
                          <p class="entry__question">{e.question[locale]}</p>
                        </a>
                      ) : (
                        <div class="entry__body">
                          <h4 class="entry__title">
                            {e.title[locale]}
                            {e.status === 'next' && (
                              <span class="entry__kicker">{t('roadmap.statusNext', locale)}</span>
                            )}
                          </h4>
                          <p class="entry__question">{e.question[locale]}</p>
                          {e.effort && (
                            <span class="entry__effort tabular" aria-hidden="true">
                              {'·'.repeat(e.effort)}
                            </span>
                          )}
                          <span class="sr-only">
                            {e.status === 'planned'
                              ? t('roadmap.statusPlanned', locale)
                              : t('roadmap.statusNext', locale)}
                          </span>
                        </div>
                      )}
                    </li>
                  );
                })}
              </ul>
            </li>
          );
        })}
      </ol>
    </div>
  </div>
</section>

<style>
  .roadmap {
    padding-block: var(--rhythm) var(--rhythm-loose);
    border-block-start: 1px solid var(--border);
  }

  /* ─── Head ───────────────────────────────────────────────── */
  .roadmap__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
    margin-block-end: var(--space-xl);
    padding-block-end: var(--space-md);
    border-block-end: 1px solid var(--border);
    flex-wrap: wrap;
  }
  .roadmap__title {
    font-size: var(--text-md);
    color: var(--ink-muted);
    font-weight: var(--weight-medium);
    margin: 0;
  }
  .roadmap__lede {
    margin: 0;
    color: var(--ink-subtle);
    font-size: var(--text-xs);
    font-style: italic;
  }

  /* ─── Body — contenitore col percorso ──────────────────── */
  .roadmap__body {
    position: relative;
    /* L'altezza è imposta dalla geometria HTML; il SVG si adatta. */
  }

  /* ─── Linea centrale ────────────────────────────────────── */
  /* Una linea verticale al centro: due div sovrapposti, animati via
     transform: scaleY (più performante di stroke-dashoffset). */
  .roadmap__line {
    position: absolute;
    inset-block: 0;
    inset-inline-start: 50%;
    inline-size: 1.75px;
    transform: translateX(-50%);
    pointer-events: none;
    z-index: 0;
    border-radius: 1px;
  }
  .roadmap__line--base {
    background-color: color-mix(in oklab, var(--border) 70%, transparent);
  }
  .roadmap__line--active {
    background-color: var(--accent);
    inline-size: 2px;
    transform: translateX(-50%) scaleY(0);
    transform-origin: center top;
    will-change: transform;
  }

  @supports (animation-timeline: view()) {
    .roadmap__body { view-timeline-name: --roadmap-progress; }
    .roadmap__line--active {
      animation: roadmap-fill linear forwards;
      animation-timeline: --roadmap-progress;
      /* `entry 50% exit 0%` = inizia quando il top della sezione tocca
         il centro della viewport, finisce quando il bottom della sezione
         tocca il top della viewport. Più tollerante al footer corto:
         così la linea raggiunge il 100% quando l'utente vede l'ultimo
         capitolo allineato al top, anche se sotto c'è poco contenuto. */
      animation-range: entry 50% exit 0%;
    }
    @keyframes roadmap-fill {
      to { transform: translateX(-50%) scaleY(1); }
    }
  }

  /* ─── Nodi sulla linea centrale ─────────────────────────── */
  .roadmap__node {
    position: absolute;
    inset-inline-start: 50%; /* sempre sulla linea centrale */
    inline-size: 18px;
    block-size: 18px;
    border-radius: 999px;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 1; /* sopra le linee */
    border: 1.5px solid currentColor;
    background-color: var(--bg);
    transition:
      transform var(--dur-normal) var(--ease-out-snug),
      border-width var(--dur-normal) var(--ease-out-snug);
  }
  .roadmap__node::after {
    /* "Pallino" interno (raggio 4 nel SVG ⇒ 8px). */
    content: '';
    position: absolute;
    inset: 50%;
    inline-size: 8px;
    block-size: 8px;
    border-radius: 999px;
    transform: translate(-50%, -50%);
    background-color: transparent;
    transition: background-color var(--dur-normal) var(--ease-out-snug);
  }

  .roadmap__node--published { color: var(--accent); }
  .roadmap__node--published::after { background-color: var(--accent); }

  .roadmap__node--next {
    color: var(--accent);
    border-width: 2px;
    /* halo pulsante: percepibile ma silenzioso, niente scale/opacity sul nodo
       (sostituisce il vecchio scale 1.15 + opacity drop). */
    animation: node-halo-pulse 2400ms var(--ease-in-out) infinite;
  }
  @keyframes node-halo-pulse {
    0%, 100% { box-shadow: 0 0 0 0 color-mix(in oklab, var(--accent) 40%, transparent); }
    50%      { box-shadow: 0 0 0 6px color-mix(in oklab, var(--accent) 0%, transparent); }
  }

  .roadmap__node--planned {
    color: var(--border-strong);
    border-style: dashed;
    opacity: 0.55;
  }

  /* Hover entry → nodo si ingrandisce sottilmente (relazione visiva). */
  .roadmap__node[data-hover='true'] {
    transform: translate(-50%, -50%) scale(1.18);
  }

  /* ─── Lista capitoli ────────────────────────────────────── */
  .roadmap__list {
    position: relative;
    z-index: 1;
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
  }

  .phase {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: var(--space-2xl);
    row-gap: 0;
  }

  /* ─── Phase header — full-width, sopra il path ─────────── */
  .phase__head {
    grid-column: 1 / -1;
    block-size: 5rem; /* deve combaciare con PHASE_H sopra */
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    color: var(--ink-muted);
    /* bg opaco che "spezza" il path che vi passa dietro: il phase__head è
       a z-index: 1 (su .roadmap__list), il path SVG è a z-index: 0,
       quindi il bg solido lo copre naturalmente senza bisogno di mask. */
    background-color: var(--bg);
    text-align: center;
  }
  .phase__letter {
    font-family: var(--font-mono);
    font-size: var(--text-md);
    color: var(--ink-strong);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
    padding: 0.25rem 0.65rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border);
    background-color: var(--surface);
    line-height: 1;
  }
  .phase__label {
    font-size: var(--text-xs);
    color: var(--ink-muted);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
  }

  /* ─── Entries ───────────────────────────────────────────── */
  .phase__entries {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: var(--space-2xl);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .entry {
    block-size: 9rem; /* deve combaciare con ENTRY_H sopra */
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding-inline: var(--space-md);

    opacity: 0;
    transform: translateY(8px);
    will-change: opacity, transform;
  }
  .entry--l {
    grid-column: 1;
    justify-self: end;
    text-align: end;
    flex-direction: row-reverse; /* body sx, numero dx (vicino alla linea) */
    transform: translate(-8px, 8px);
  }
  .entry--r {
    grid-column: 2;
    justify-self: start;
    flex-direction: row; /* numero sx (vicino alla linea), body dx */
    transform: translate(8px, 8px);
  }

  .entry[data-revealed='true'] {
    opacity: 1;
    transform: translate(0, 0);
    transition:
      opacity 520ms var(--ease-out-soft) calc(var(--i, 0) * 30ms),
      transform 560ms var(--ease-out-snug) calc(var(--i, 0) * 30ms);
  }

  /* Numero capitolo — flex item, allineamento verticale gestito da `.entry`.
     Si "accende" quando la linea attiva passa il nodo (data-passed='true')
     e SOLO se il capitolo è pubblicato — i numeri di next/planned restano
     spenti perché non c'è ancora un capitolo da raggiungere. */
  .entry__num {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: var(--text-md);
    color: var(--ink-subtle);
    letter-spacing: var(--tracking-wide);
    line-height: 1;
    transition: color var(--dur-normal) var(--ease-out-snug);
  }
  .entry[data-status='published'][data-passed='true'] .entry__num {
    color: var(--accent);
  }

  /* Body */
  .entry__body {
    display: grid;
    gap: var(--space-3xs);
    text-decoration: none;
    color: inherit;
    padding: var(--space-2xs) var(--space-sm);
    border-radius: var(--radius-md);
    background-color: color-mix(in oklab, var(--bg) 88%, transparent);
    border: 1px solid transparent;
    transition:
      transform var(--dur-fast) var(--ease-out-soft),
      border-color var(--dur-fast) var(--ease-out-soft),
      background-color var(--dur-fast) var(--ease-out-soft);
  }

  a.entry__body:hover {
    border-color: var(--border);
    background-color: var(--surface-raised);
  }
  a.entry__body:focus-visible {
    outline: none;
    box-shadow: var(--halo-focus);
    border-color: var(--accent);
  }
  a.entry__body:hover .entry__title { color: var(--accent-ink); }

  .entry__title {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-snug);
    font-weight: var(--weight-medium);
    color: var(--ink-strong);
    transition: color var(--dur-fast) var(--ease-out-soft);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2xs);
  }
  .entry--l .entry__title { justify-content: flex-end; }
  .entry__question {
    margin: 0;
    font-size: var(--text-xs);
    line-height: var(--leading-relaxed);
    color: var(--ink-muted);
    max-inline-size: 30ch;
  }
  .entry--l .entry__question { margin-inline-start: auto; }

  /* Stati */
  [data-status='next'] .entry__kicker {
    font-size: var(--text-2xs);
    color: var(--accent-ink);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    padding-inline: 0.45rem;
    padding-block: 0.05rem;
    border-radius: var(--radius-pill);
    background-color: color-mix(in oklab, var(--accent) 14%, transparent);
  }
  [data-status='planned'] .entry__title {
    color: var(--ink-muted);
    font-weight: var(--weight-regular);
  }
  [data-status='planned'] .entry__question { color: var(--ink-subtle); }

  .entry__effort {
    color: var(--ink-subtle);
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    opacity: 0.6;
    letter-spacing: 0.15em;
  }
  .entry--l .entry__effort { text-align: end; }

  /* ─── sr-only ────────────────────────────────────────────── */
  .sr-only {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ─── Mobile fallback: una colonna, niente linea centrale ─── */
  @media (max-width: 39rem) {
    .roadmap__line,
    .roadmap__node { display: none; }

    .phase {
      grid-template-columns: 1fr;
    }
    .phase__entries {
      grid-template-columns: 1fr;
      border-inline-start: 2px solid var(--border);
      padding-inline-start: var(--space-lg);
      margin-inline-start: var(--space-2xs);
    }
    .entry {
      block-size: auto;
      min-block-size: 7rem;
      padding-block: var(--space-sm);
    }
    .entry--l, .entry--r {
      grid-column: 1;
      flex-direction: row; /* su mobile sempre numero a sx, body a dx */
      justify-self: stretch;
      text-align: start;
      transform: translateY(8px); /* per il reveal */
    }
    .entry--l .entry__title { justify-content: flex-start; }
    .entry--l .entry__question { margin-inline-start: 0; }
    .entry--l .entry__effort { text-align: start; }

    .phase__head {
      block-size: auto;
      padding-block: var(--space-md);
      justify-content: flex-start;
      background: none;
    }
  }

  /* ─── Reduced motion ────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .entry,
    .entry[data-revealed='true'] {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .roadmap__line--active {
      animation: none !important;
      transform: translateX(-50%) scaleY(1); /* linea piena, niente disegno */
    }
    .roadmap__node--next { animation: none; box-shadow: none; }
    .roadmap__node,
    .roadmap__node[data-hover='true'] {
      transition: none;
      transform: translate(-50%, -50%); /* niente scale al hover */
    }
    a.entry__body,
    .entry__title { transition: none; }
  }
</style>

<script>
  /* Bind idempotente, stesso pattern di src/components/scrolling/*.

     - Reveal a passo singolo via IntersectionObserver (unobserve dopo trigger).
       Ogni entry rivela il proprio nodo SVG corrispondente: il piccolo "ping"
       del nodo è coordinato col fade-in del corpo.

     - Fallback drawing: se il browser non supporta animation-timeline: view(),
       calcoliamo il progresso dello scroll della sezione e aggiorniamo
       stroke-dashoffset in passive scroll (1000 → 0). */
  function bind() {
    document.querySelectorAll<HTMLElement>('.roadmap').forEach((root) => {
      if (root.dataset.bound === 'true') return;
      root.dataset.bound = 'true';

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      /* ── Reveal entries + accensione dei nodi corrispondenti ── */
      const entries = root.querySelectorAll<HTMLElement>('.entry');
      const nodeByIndex = new Map<number, HTMLElement>();
      root.querySelectorAll<HTMLElement>('.roadmap__node').forEach((n) => {
        const idx = Number(n.dataset.nodeIndex);
        if (Number.isFinite(idx)) nodeByIndex.set(idx, n);
      });

      if (reduced) {
        entries.forEach((el) => {
          el.dataset.revealed = 'true';
          if (el.dataset.status === 'published') el.dataset.passed = 'true';
        });
        nodeByIndex.forEach((n) => (n.dataset.revealed = 'true'));
      } else {
        const obs = new IntersectionObserver(
          (records) => {
            records.forEach((rec) => {
              if (rec.isIntersecting && rec.target instanceof HTMLElement) {
                const el = rec.target;
                el.dataset.revealed = 'true';
                const idx = Number(el.dataset.index);
                const node = nodeByIndex.get(idx);
                if (node) node.dataset.revealed = 'true';
                obs.unobserve(el);
              }
            });
          },
          { threshold: 0.35 },
        );
        entries.forEach((el) => obs.observe(el));

        /* ── "Accensione" del numero quando la linea attiva passa il nodo ──
           Solo per i capitoli pubblicati: trigger esattamente al centro
           viewport (rootMargin -50% top/bottom = fascia attiva ridotta a
           una linea orizzontale al centro), così il numero si accende
           proprio quando la linea raggiunge il suo nodo. */
        const obsPassed = new IntersectionObserver(
          (records) => {
            records.forEach((rec) => {
              if (rec.isIntersecting && rec.target instanceof HTMLElement) {
                rec.target.dataset.passed = 'true';
                obsPassed.unobserve(rec.target);
              }
            });
          },
          { rootMargin: '-50% 0px -50% 0px', threshold: 0 },
        );
        entries.forEach((el) => {
          if (el.dataset.status === 'published') obsPassed.observe(el);
        });

        /* ── Hover entry → nodo si illumina (delegated, idempotente) ── */
        const list = root.querySelector<HTMLElement>('.roadmap__list');
        if (list) {
          const setHover = (e: Event, on: boolean) => {
            const target = e.target;
            if (!(target instanceof HTMLElement)) return;
            const entry = target.closest('.entry') as HTMLElement | null;
            if (!entry) return;
            const idx = Number(entry.dataset.index);
            const node = nodeByIndex.get(idx);
            if (!node) return;
            if (on) node.dataset.hover = 'true';
            else delete node.dataset.hover;
          };
          list.addEventListener('mouseover', (e) => setHover(e, true));
          list.addEventListener('mouseout', (e) => setHover(e, false));
        }
      }

      /* ── Fallback drawing della linea ──
         Sync col centro della viewport, normalizzato in modo che la linea
         raggiunga il 100% quando il bottom della sezione tocca il top
         viewport (equivalente a `animation-range: entry 50% exit 0%`).
         Tollerante al fondo pagina corto: l'utente non deve scrollare
         oltre il footer per completare l'animazione. */
      const supportsTL =
        CSS.supports?.('animation-timeline: view()') ?? false;
      if (!supportsTL && !reduced) {
        const body = root.querySelector<HTMLElement>('[data-roadmap]');
        const line = root.querySelector<HTMLElement>('[data-line]');
        if (body && line) {
          let ticking = false;
          const update = () => {
            const rect = body.getBoundingClientRect();
            const vh = window.innerHeight || document.documentElement.clientHeight;
            const cursorY = vh / 2; // centro viewport in coordinate viewport
            // Distanza del centro viewport dal top della sezione, normalizzata
            // su (rect.height - vh/2) così che ratio=1 quando il bottom della
            // sezione tocca il top viewport.
            const range = Math.max(1, rect.height - vh / 2);
            const filled = Math.min(range, Math.max(0, cursorY - rect.top));
            const ratio = filled / range;
            line.style.transform = `translateX(-50%) scaleY(${ratio})`;
            ticking = false;
          };
          const onScroll = () => {
            if (!ticking) {
              window.requestAnimationFrame(update);
              ticking = true;
            }
          };
          window.addEventListener('scroll', onScroll, { passive: true });
          window.addEventListener('resize', onScroll, { passive: true });
          update();
        }
      }
    });
  }

  document.addEventListener('astro:page-load', bind);
</script>
