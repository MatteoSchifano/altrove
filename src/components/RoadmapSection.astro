---
/* ─────────────────────────────────────────────────────────────
   RoadmapSection — la mappa lunga del libro.

   Mostra l'intero arco dei 26 capitoli, suddivisi in 4 fasi
   (A primi 8 · B componenti · C editoriali · D complessi), con
   stato visibile a colpo d'occhio:
     • published → cerchio pieno, titolo nero, link cliccabile
     • next      → cerchio anello, kicker "Prossimo"
     • planned   → trattino, titolo in ink-muted

   Tre meccanismi di scroll, tutti dal vocabolario del cap. 05:
   1. Reveal a passo singolo (IntersectionObserver, unobserve)
   2. Filo verticale di progresso (view-timeline + fallback JS)
   3. Scroll-spy sul phase header attivo (IntersectionObserver)

   Niente pinning, niente scrub continuo, niente parallasse —
   lo scroll è informazione, non spettacolo.
   ───────────────────────────────────────────────────────────── */

import {
  ROADMAP,
  PHASE_LABEL,
  mergeWithCollection,
  type Phase,
  type MergedRoadmapEntry,
} from '../lib/roadmap';
import { t, type Locale } from '../lib/i18n';
import type { CollectionEntry } from 'astro:content';

interface Props {
  locale: Locale;
  publishedChapters: ReadonlyArray<CollectionEntry<'chapters'>>;
}
const { locale, publishedChapters } = Astro.props;

const entries = mergeWithCollection(publishedChapters, locale);

// Raggruppo per fase preservando l'ordine numerico.
const PHASES: readonly Phase[] = ['A', 'B', 'C', 'D'] as const;
const byPhase = new Map<Phase, MergedRoadmapEntry[]>();
for (const ph of PHASES) byPhase.set(ph, []);
for (const e of entries) byPhase.get(e.phase)!.push(e);
---

<section class="roadmap" aria-labelledby="roadmap-title">
  <div class="container">
    <header class="roadmap__head">
      <h2 id="roadmap-title" class="roadmap__title">{t('home.roadmapTitle', locale)}</h2>
      <p class="roadmap__lede">{t('home.roadmapLede', locale)}</p>
    </header>

    <div class="roadmap__body" data-roadmap>
      <span class="roadmap__rail" aria-hidden="true">
        <span class="roadmap__fill" data-fill></span>
      </span>

      <ol class="roadmap__list" data-list>
        {PHASES.map((phase) => {
          const items = byPhase.get(phase)!;
          if (items.length === 0) return null;
          return (
            <li class="phase">
              <h3 class="phase__head" data-phase={phase}>
                <span class="phase__letter tabular">{phase}</span>
                <span class="phase__label">{PHASE_LABEL[phase][locale]}</span>
              </h3>

              <ul role="list" class="phase__entries">
                {items.map((e, i) => {
                  const isLink = e.status === 'published' && e.href;
                  const ariaCurrent = e.status === 'next' ? 'step' : undefined;
                  return (
                    <li
                      class="entry"
                      data-status={e.status}
                      style={`--i:${i}`}
                      aria-current={ariaCurrent}
                    >
                      <span class="entry__gutter" aria-hidden="true">
                        <span class="entry__num tabular">{e.number}</span>
                        <span class={`entry__glyph entry__glyph--${e.status}`}></span>
                      </span>

                      {isLink ? (
                        <a class="entry__body" href={e.href!}>
                          <h4 class="entry__title">{e.title[locale]}</h4>
                          <p class="entry__question">{e.question[locale]}</p>
                        </a>
                      ) : (
                        <div class="entry__body">
                          <h4 class="entry__title">
                            {e.title[locale]}
                            {e.status === 'next' && (
                              <span class="entry__kicker">{t('roadmap.statusNext', locale)}</span>
                            )}
                          </h4>
                          <p class="entry__question">{e.question[locale]}</p>
                          {e.effort && (
                            <span class="entry__effort tabular" aria-hidden="true">
                              {'·'.repeat(e.effort)}
                            </span>
                          )}
                          <span class="sr-only">
                            {e.status === 'planned'
                              ? t('roadmap.statusPlanned', locale)
                              : t('roadmap.statusNext', locale)}
                          </span>
                        </div>
                      )}
                    </li>
                  );
                })}
              </ul>
            </li>
          );
        })}
      </ol>
    </div>
  </div>
</section>

<style>
  .roadmap {
    padding-block: var(--rhythm) var(--rhythm-loose);
    border-block-start: 1px solid var(--border);
  }

  /* ─── Head ───────────────────────────────────────────────── */
  .roadmap__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
    margin-block-end: var(--space-xl);
    padding-block-end: var(--space-md);
    border-block-end: 1px solid var(--border);
    flex-wrap: wrap;
  }
  .roadmap__title {
    font-size: var(--text-md);
    color: var(--ink-muted);
    font-weight: var(--weight-medium);
    margin: 0;
  }
  .roadmap__lede {
    margin: 0;
    color: var(--ink-subtle);
    font-size: var(--text-xs);
    font-style: italic;
  }

  /* ─── Body con filo a sinistra ──────────────────────────── */
  .roadmap__body {
    position: relative;
    max-inline-size: var(--measure-loose);
  }

  /* Il filo è una colonna sottile a sinistra; il fill cresce
     dall'alto via animation-timeline / fallback JS. */
  .roadmap__rail {
    position: absolute;
    inset-block: 0;
    inset-inline-start: calc(var(--gutter-w) - 1px);
    inline-size: 2px;
    background-color: var(--border);
    border-radius: 999px;
    overflow: hidden;
    pointer-events: none;
  }
  .roadmap__fill {
    display: block;
    block-size: 100%;
    inline-size: 100%;
    background: linear-gradient(
      to bottom,
      var(--accent) 0%,
      color-mix(in oklab, var(--accent), var(--ink-subtle) 50%) 100%
    );
    transform-origin: top center;
    transform: scaleY(0);
    will-change: transform;
  }

  /* View-timeline nativo: il filo si riempie mentre la sezione
     attraversa il viewport. Su browser senza supporto, il
     fallback JS (script in coda) applica scaleY in passive. */
  @supports (animation-timeline: view()) {
    .roadmap__body { view-timeline-name: --roadmap-progress; }
    .roadmap__fill {
      animation: roadmap-fill linear forwards;
      animation-timeline: --roadmap-progress;
      animation-range: cover 0% cover 100%;
    }
    @keyframes roadmap-fill {
      to { transform: scaleY(1); }
    }
  }

  /* ─── Lista capitoli ────────────────────────────────────── */
  .roadmap__list {
    --gutter-w: 3rem;
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-xl);
  }
  @media (min-width: 48rem) {
    .roadmap__list { --gutter-w: 4.5rem; }
  }

  .phase {
    display: grid;
    gap: var(--space-md);
  }

  /* ─── Phase header (sticky) ─────────────────────────────── */
  .phase__head {
    position: sticky;
    /* sotto l'header globale (~4.5rem) + un po' di respiro */
    inset-block-start: clamp(4rem, 6vh, 5.5rem);
    z-index: 1;
    display: grid;
    grid-template-columns: var(--gutter-w) 1fr;
    align-items: baseline;
    gap: var(--space-2xs);
    margin: 0;
    padding-block: var(--space-2xs);
    background: linear-gradient(
      to bottom,
      var(--bg) 0%,
      var(--bg) 60%,
      color-mix(in oklab, var(--bg), transparent 100%) 100%
    );
    transition: color var(--dur-normal) var(--ease-out-soft);
  }
  .phase__letter {
    grid-column: 1;
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    color: var(--ink-subtle);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    line-height: var(--leading-tight);
  }
  .phase__label {
    grid-column: 2;
    font-size: var(--text-xs);
    color: var(--ink-subtle);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    transition: color var(--dur-normal) var(--ease-out-soft);
  }
  .phase__head[data-active] .phase__letter,
  .phase__head[data-active] .phase__label {
    color: var(--ink-strong);
  }

  /* ─── Entries ───────────────────────────────────────────── */
  .phase__entries {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-md);
  }

  .entry {
    display: grid;
    grid-template-columns: var(--gutter-w) 1fr;
    gap: var(--space-sm);
    align-items: start;

    opacity: 0;
    transform: translateY(8px);
    will-change: opacity, transform;
  }
  .entry[data-revealed='true'] {
    opacity: 1;
    transform: none;
    transition:
      opacity 480ms var(--ease-out-soft) calc(var(--i, 0) * 30ms),
      transform 520ms var(--ease-out-snug) calc(var(--i, 0) * 30ms);
  }

  /* Gutter (numero + glifo allineati al filo) */
  .entry__gutter {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    gap: var(--space-2xs);
    padding-inline-end: var(--space-2xs);
    min-block-size: 1.5rem;
  }
  .entry__num {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-subtle);
    letter-spacing: var(--tracking-wide);
    line-height: 1;
  }
  /* Il glifo è agganciato al filo (centrato sul rail di 2px) */
  .entry__glyph {
    grid-column: 2;
    inline-size: 8px;
    block-size: 8px;
    margin-inline-start: calc(var(--space-2xs) * -1);
    background-color: var(--border-strong);
    border-radius: 50%;
    align-self: center;
    transform: translateX(50%);
    position: relative;
    z-index: 1; /* sopra il rail */
  }
  .entry__glyph--published {
    background-color: var(--accent);
    inline-size: 8px;
    block-size: 8px;
  }
  .entry__glyph--next {
    background-color: var(--bg);
    box-shadow: inset 0 0 0 1.5px var(--accent);
    inline-size: 10px;
    block-size: 10px;
  }
  .entry__glyph--planned {
    background-color: var(--bg);
    border-radius: 0;
    inline-size: 8px;
    block-size: 2px;
    box-shadow: inset 0 0 0 1px var(--border-strong);
  }

  /* Body — sia <a> sia <div> condividono questi stili */
  .entry__body {
    display: grid;
    gap: var(--space-3xs);
    text-decoration: none;
    color: inherit;
    padding-block: var(--space-3xs);
    border-radius: var(--radius-sm);
    transition: transform var(--dur-fast) var(--ease-out-soft);
  }
  a.entry__body:hover { transform: translateX(2px); }
  a.entry__body:focus-visible {
    outline: none;
    box-shadow: var(--halo-focus);
  }
  a.entry__body:hover .entry__title {
    color: var(--accent-ink);
  }

  .entry__title {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-snug);
    font-weight: var(--weight-medium);
    color: var(--ink-strong);
    transition: color var(--dur-fast) var(--ease-out-soft);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2xs);
  }
  .entry__question {
    margin: 0;
    font-size: var(--text-xs);
    line-height: var(--leading-relaxed);
    color: var(--ink-muted);
    max-inline-size: 46ch;
  }

  /* Stati visivi */
  [data-status='next'] .entry__title { color: var(--ink-strong); }
  [data-status='next'] .entry__kicker {
    font-size: var(--text-2xs);
    color: var(--accent-ink);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    padding-inline: 0.45rem;
    padding-block: 0.05rem;
    border-radius: var(--radius-pill);
    background-color: color-mix(in oklab, var(--accent) 14%, transparent);
  }
  [data-status='planned'] .entry__title {
    color: var(--ink-muted);
    font-weight: var(--weight-regular);
  }
  [data-status='planned'] .entry__question { color: var(--ink-subtle); }

  /* Effort (puntini) */
  .entry__effort {
    color: var(--ink-subtle);
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    opacity: 0.6;
    letter-spacing: 0.15em;
    margin-block-start: var(--space-3xs);
  }

  /* sr-only — pattern standard */
  .sr-only {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ─── Reduced motion ────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .entry,
    .entry[data-revealed='true'] {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .roadmap__fill {
      animation: none !important;
      transform: scaleY(1);
    }
    .phase__head,
    .phase__label,
    a.entry__body,
    .entry__title { transition: none; }
  }
</style>

<script>
  /* Bind idempotente, pattern di src/components/scrolling/*.
     - Reveal a passo singolo via IntersectionObserver (unobserve dopo trigger)
     - Scroll-spy sul phase header (rootMargin -40/-55%)
     - Fallback filo: se animation-timeline non è supportato, scaleY via passive scroll */
  function bind() {
    document.querySelectorAll<HTMLElement>('.roadmap').forEach((root) => {
      if (root.dataset.bound === 'true') return;
      root.dataset.bound = 'true';

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      /* ── Reveal ── */
      const entries = root.querySelectorAll<HTMLElement>('.entry');
      if (reduced) {
        entries.forEach((el) => (el.dataset.revealed = 'true'));
      } else {
        const revealObserver = new IntersectionObserver(
          (records) => {
            records.forEach((rec) => {
              if (rec.isIntersecting && rec.target instanceof HTMLElement) {
                rec.target.dataset.revealed = 'true';
                revealObserver.unobserve(rec.target);
              }
            });
          },
          { threshold: 0.2 },
        );
        entries.forEach((el) => revealObserver.observe(el));
      }

      /* ── Scroll-spy phase header ── */
      const phaseHeads = Array.from(root.querySelectorAll<HTMLElement>('.phase__head'));
      const phaseBlocks = phaseHeads
        .map((h) => h.closest<HTMLElement>('.phase'))
        .filter((el): el is HTMLElement => el !== null);

      const setActive = (idx: number) => {
        phaseHeads.forEach((h, i) => {
          if (i === idx) h.dataset.active = 'true';
          else delete h.dataset.active;
        });
      };

      if (phaseBlocks.length > 0) {
        const ratios = new Map<number, number>();
        const spy = new IntersectionObserver(
          (records) => {
            records.forEach((rec) => {
              const idx = phaseBlocks.indexOf(rec.target as HTMLElement);
              if (idx >= 0) {
                ratios.set(idx, rec.isIntersecting ? rec.intersectionRatio : 0);
              }
            });
            let bestIdx = -1;
            let bestR = 0;
            ratios.forEach((r, i) => {
              if (r > bestR) {
                bestR = r;
                bestIdx = i;
              }
            });
            if (bestIdx >= 0) setActive(bestIdx);
          },
          {
            threshold: [0.1, 0.3, 0.6, 0.9],
            rootMargin: '-40% 0px -55% 0px',
          },
        );
        phaseBlocks.forEach((b) => spy.observe(b));
        setActive(0); // stato iniziale: prima fase attiva
      }

      /* ── Fallback filo (se animation-timeline non supportato) ── */
      const supportsTL =
        CSS.supports?.('animation-timeline: view()') ?? false;
      if (!supportsTL && !reduced) {
        const body = root.querySelector<HTMLElement>('[data-roadmap]');
        const fill = root.querySelector<HTMLElement>('[data-fill]');
        if (body && fill) {
          let ticking = false;
          const update = () => {
            const rect = body.getBoundingClientRect();
            const vh = window.innerHeight || document.documentElement.clientHeight;
            // 0 quando il top della sezione è alla bottom edge del viewport;
            // 1 quando il bottom della sezione è alla top edge del viewport.
            const total = rect.height + vh;
            const progressed = vh - rect.top;
            const ratio = Math.min(1, Math.max(0, progressed / total));
            fill.style.transform = `scaleY(${ratio.toFixed(3)})`;
            ticking = false;
          };
          const onScroll = () => {
            if (!ticking) {
              window.requestAnimationFrame(update);
              ticking = true;
            }
          };
          window.addEventListener('scroll', onScroll, { passive: true });
          window.addEventListener('resize', onScroll, { passive: true });
          update();
        }
      }
    });
  }

  document.addEventListener('astro:page-load', bind);
</script>
