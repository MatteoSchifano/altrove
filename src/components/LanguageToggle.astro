---
/* ─────────────────────────────────────────────────────────────
   LanguageToggle — switch tra italiano e inglese.

   Mostra l'etichetta breve della locale corrente (IT/EN) e
   funziona da link verso la versione corrispondente della stessa
   pagina nell'altra lingua. Per i capitoli, l'`href` è precalcolato
   nel `Chapter.astro` e passato come prop, perché lo slug può
   essere diverso tra le lingue (es. /chapters/01-anatomia → /en/chapters/01-anatomy).
   ───────────────────────────────────────────────────────────── */

import { LOCALE_SHORT, LOCALE_LABEL, t, type Locale } from '../lib/i18n';

interface Props {
  currentLocale: Locale;
  /** href verso la versione tradotta della pagina corrente */
  alternateHref: string;
  /** locale di destinazione (per aria + label) */
  alternateLocale: Locale;
}

const { currentLocale, alternateHref, alternateLocale } = Astro.props;
const ariaLabel = `${t('header.langAria', currentLocale)} — ${LOCALE_LABEL[alternateLocale]}`;
---

<a
  class="lang-toggle"
  href={alternateHref}
  aria-label={ariaLabel}
  hreflang={alternateLocale}
  data-astro-reload={alternateLocale === 'it' ? undefined : true}
>
  <span class="lang-toggle__current" aria-hidden="true">{LOCALE_SHORT[currentLocale]}</span>
  <span class="lang-toggle__sep" aria-hidden="true">/</span>
  <span class="lang-toggle__alternate" aria-hidden="true">{LOCALE_SHORT[alternateLocale]}</span>
</a>

<style>
  .lang-toggle {
    --pad: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    block-size: 2.5rem;
    padding-inline: 0.875rem;
    border-radius: var(--radius-pill);
    background-color: var(--surface);
    border: 1px solid var(--border);
    color: var(--ink-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wider);
    text-decoration: none;
    transition:
      color var(--dur-fast) var(--ease-out-soft),
      background-color var(--dur-fast) var(--ease-out-soft),
      border-color var(--dur-fast) var(--ease-out-soft);
  }

  .lang-toggle:hover {
    color: var(--ink-strong);
    background-color: var(--surface-raised);
    border-color: var(--border-strong);
  }

  .lang-toggle:hover .lang-toggle__alternate {
    color: var(--accent);
  }

  .lang-toggle:focus-visible {
    outline: none;
    box-shadow: var(--halo-focus);
  }

  .lang-toggle__current {
    color: var(--ink-strong);
  }

  .lang-toggle__sep {
    color: var(--ink-subtle);
  }

  .lang-toggle__alternate {
    color: var(--ink-subtle);
    transition: color var(--dur-fast) var(--ease-out-soft);
  }
</style>
