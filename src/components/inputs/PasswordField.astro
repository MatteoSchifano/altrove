---
/* ─────────────────────────────────────────────────────────────
   PasswordField — visibilità su richiesta, forza misurata.

   Pattern: il campo password ha due piccole tensioni. La prima è
   che non si vede mai cosa si è scritto (e quando si sbaglia è
   un dramma); la seconda è che la "forza" è un concetto che il
   sistema sa e l'utente no. Si risolvono insieme: un toggle eye
   con `aria-pressed` per togliere la cecità, e quattro barrette
   che descrivono in silenzio la qualità di ciò che si scrive.

   Strength: lunghezza ≥ 8, maiuscole, numeri, simboli — quattro
   indizi, quattro barrette. Non è la verità scientifica, è una
   metafora onesta.
   ───────────────────────────────────────────────────────────── */
---

<form class="pwd" autocomplete="off" onsubmit="return false;">
  <label class="pwd__label" for="pwd-input">Password</label>
  <div class="pwd__field">
    <input class="pwd__input" id="pwd-input" type="password" placeholder="Almeno 8 caratteri" />
    <button class="pwd__toggle" type="button" aria-label="Mostra password" aria-pressed="false" data-toggle>
      <svg class="pwd__icon-eye" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M1 8s2.5-4.5 7-4.5S15 8 15 8s-2.5 4.5-7 4.5S1 8 1 8z" />
        <circle cx="8" cy="8" r="2" />
      </svg>
      <svg class="pwd__icon-eye-off" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M2 2l12 12M6.5 6.5a2 2 0 0 0 2.8 2.8M3.5 4.5C2 5.7 1 8 1 8s2.5 4.5 7 4.5c1.5 0 2.7-.4 3.7-1M9.5 3.6c-.5-.1-1-.1-1.5-.1C3.5 3.5 1 8 1 8" />
      </svg>
    </button>
  </div>
  <div class="pwd__meter" data-strength="0" aria-hidden="true">
    <span class="pwd__bar"></span>
    <span class="pwd__bar"></span>
    <span class="pwd__bar"></span>
    <span class="pwd__bar"></span>
  </div>
  <p class="pwd__hint" data-hint aria-live="polite">Inizia a digitare.</p>
</form>

<style>
  .pwd {
    inline-size: min(26rem, 100%);
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .pwd__label {
    font-size: var(--text-2xs);
    color: var(--ink-subtle);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
  }

  .pwd__field {
    display: flex;
    align-items: center;
    padding: 0 0.4rem 0 var(--space-md);
    border-radius: var(--radius-md);
    background: var(--surface-raised);
    border: 1px solid var(--border);
    transition: border-color var(--dur-fast) var(--ease-out-soft);
  }
  .pwd__field:focus-within {
    border-color: var(--ink-muted);
  }

  .pwd__input {
    flex: 1;
    padding: 0.7rem 0;
    background: transparent;
    border: 0;
    color: var(--ink-strong);
    font-size: var(--text-sm);
    font-family: inherit;
    outline: 0;
    letter-spacing: 0.02em;
  }
  .pwd__input:focus,
  .pwd__input:focus-visible {
    outline: 0;
    box-shadow: none;
  }

  .pwd__toggle {
    flex: 0 0 auto;
    inline-size: 2rem;
    block-size: 2rem;
    display: grid;
    place-items: center;
    background: transparent;
    border: 0;
    border-radius: var(--radius-sm);
    color: var(--ink-subtle);
    cursor: pointer;
    transition: color var(--dur-fast) var(--ease-out-soft);
  }
  .pwd__toggle:hover { color: var(--ink); }
  .pwd__toggle:focus-visible { outline: none; box-shadow: var(--halo-focus); }
  .pwd__toggle svg { inline-size: 1rem; block-size: 1rem; }
  .pwd__icon-eye-off { display: none; }
  .pwd__toggle[aria-pressed='true'] .pwd__icon-eye { display: none; }
  .pwd__toggle[aria-pressed='true'] .pwd__icon-eye-off { display: block; }

  .pwd__meter {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3xs);
    margin-block-start: var(--space-3xs);
  }
  .pwd__bar {
    block-size: 4px;
    border-radius: var(--radius-pill);
    background: var(--surface-sunken);
    transition: background-color var(--dur-fast) var(--ease-out-soft);
  }
  .pwd__meter[data-strength='1'] .pwd__bar:nth-child(-n+1) { background: oklch(0.55 0.18 22); }
  .pwd__meter[data-strength='2'] .pwd__bar:nth-child(-n+2) { background: oklch(0.75 0.16 80); }
  .pwd__meter[data-strength='3'] .pwd__bar:nth-child(-n+3) { background: oklch(0.62 0.16 110); }
  .pwd__meter[data-strength='4'] .pwd__bar { background: oklch(0.55 0.16 145); }

  .pwd__hint {
    margin: 0;
    min-block-size: 1.1rem;
    font-size: var(--text-2xs);
    color: var(--ink-subtle);
  }

  @media (prefers-reduced-motion: reduce) {
    .pwd__bar,
    .pwd__field,
    .pwd__toggle { transition-duration: 1ms; }
  }
</style>

<script>
  function strength(v: string): number {
    let s = 0;
    if (v.length >= 8) s++;
    if (/[A-Z]/.test(v)) s++;
    if (/[0-9]/.test(v)) s++;
    if (/[^A-Za-z0-9]/.test(v)) s++;
    return s;
  }

  const HINTS: Record<number, string> = {
    0: 'Inizia a digitare.',
    1: 'Debole — aggiungi maiuscole.',
    2: 'Discreta — aggiungi numeri.',
    3: 'Forte.',
    4: 'Eccellente.',
  };

  function bind() {
    document.querySelectorAll<HTMLElement>('.pwd').forEach((el) => {
      if (el.dataset.bound === 'true') return;
      el.dataset.bound = 'true';

      const input = el.querySelector<HTMLInputElement>('.pwd__input')!;
      const toggle = el.querySelector<HTMLButtonElement>('[data-toggle]')!;
      const meter = el.querySelector<HTMLElement>('.pwd__meter')!;
      const hint = el.querySelector<HTMLElement>('[data-hint]')!;

      toggle.addEventListener('click', () => {
        const shown = toggle.getAttribute('aria-pressed') === 'true';
        const next = !shown;
        toggle.setAttribute('aria-pressed', String(next));
        toggle.setAttribute('aria-label', next ? 'Nascondi password' : 'Mostra password');
        input.type = next ? 'text' : 'password';
      });

      input.addEventListener('input', () => {
        const v = input.value;
        const s = v.length === 0 ? 0 : strength(v);
        meter.setAttribute('data-strength', String(s));
        hint.textContent = HINTS[s] ?? '';
      });
    });
  }

  document.addEventListener('astro:page-load', bind);
</script>
