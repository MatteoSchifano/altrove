---
/* ─────────────────────────────────────────────────────────────
   ConfirmInPlaceButton — l'alternativa elegante al modal.

   Pattern: l'azione distruttiva non apre una finestra che oscura
   la pagina; il bottone STESSO si trasforma in una piccola domanda
   contenente le due opzioni. Annulla auto-cancella dopo 4 s.

   Tre stati: idle → confirming → (idle | done)
   - idle:       pulsante "Elimina" rosso-soft
   - confirming: il bottone si allarga, rivela "Sicuro?" + due
                 azioni inline. Lo sfondo rimane silenzioso.
   - done:       breve flash di conferma, poi resetta.

   UX rationale
   - Tieni l'utente nel suo flusso (non interrompi).
   - Il rosso è usato con parsimonia: solo nello stato idle, e
     molto desaturo. La conferma usa un grigio neutro perché
     l'attenzione deve andare all'azione, non al colore.
   - Auto-cancel evita "stati appiccicosi": se l'utente cambia
     idea, non deve fare nulla.
   ───────────────────────────────────────────────────────────── */
---

<div class="confirm" data-state="idle">
  <button type="button" class="confirm__primary" data-action="ask">
    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M3 4h10M6 4V3a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v1M5 4l.5 9a1 1 0 0 0 1 1h3a1 1 0 0 0 1-1L11 4" />
    </svg>
    <span>Elimina la nota</span>
  </button>

  <div class="confirm__panel" aria-live="polite">
    <span class="confirm__question">Sicuro?</span>
    <button type="button" class="confirm__confirm" data-action="confirm">Sì, elimina</button>
    <button type="button" class="confirm__cancel" data-action="cancel" aria-label="Annulla">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 4l8 8M12 4l-8 8" />
      </svg>
    </button>
  </div>

  <div class="confirm__done" aria-hidden="true">
    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 8.5 6.5 12 13 4.5" />
    </svg>
    <span>Fatto</span>
  </div>
</div>

<style>
  .confirm {
    --pad-y: 0.625rem;
    --pad-x: 1rem;
    position: relative;
    display: inline-grid;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border);
    background-color: var(--surface-raised);
    overflow: hidden;
    transition:
      background-color var(--dur-normal) var(--ease-out-soft),
      border-color var(--dur-normal) var(--ease-out-soft),
      box-shadow var(--dur-normal) var(--ease-out-soft);
  }

  .confirm[data-state='confirming'] {
    background-color: var(--surface-sunken);
    border-color: var(--border-strong);
    box-shadow: var(--shadow-md);
  }

  /* Tutti e tre i layer occupano la stessa cella della grid:
     possono dissolversi liberamente l'uno nell'altro. */
  .confirm__primary,
  .confirm__panel,
  .confirm__done {
    grid-area: 1 / 1;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    padding: var(--pad-y) var(--pad-x);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    transition:
      opacity var(--dur-fast) var(--ease-out-soft),
      transform var(--dur-normal) var(--ease-out-snug);
  }

  /* Stato idle: visibile primary, gli altri nascosti */
  .confirm__primary {
    color: var(--ink);
  }

  .confirm__primary svg {
    inline-size: 0.95rem;
    block-size: 0.95rem;
    color: oklch(0.6 0.14 25);
  }

  .confirm__primary:hover {
    color: oklch(0.55 0.18 25);
  }

  .confirm__primary:hover svg {
    color: oklch(0.55 0.18 25);
  }

  /* Pannello di conferma */
  .confirm__panel {
    opacity: 0;
    transform: translateY(6px);
    pointer-events: none;
  }

  .confirm__question {
    color: var(--ink-strong);
    margin-inline-end: var(--space-2xs);
  }

  .confirm__confirm {
    padding: 0.25rem 0.7rem;
    border-radius: var(--radius-pill);
    background-color: oklch(0.5 0.18 25);
    color: oklch(0.99 0.01 25);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    transition: background-color var(--dur-fast) var(--ease-out-soft);
  }

  .confirm__confirm:hover {
    background-color: oklch(0.45 0.2 25);
  }

  .confirm__cancel {
    inline-size: 1.6rem;
    block-size: 1.6rem;
    border-radius: var(--radius-pill);
    color: var(--ink-muted);
    display: inline-grid;
    place-items: center;
    transition: color var(--dur-fast) var(--ease-out-soft);
  }

  .confirm__cancel:hover { color: var(--ink-strong); }
  .confirm__cancel svg { inline-size: 0.875rem; block-size: 0.875rem; }

  /* Stato done */
  .confirm__done {
    opacity: 0;
    transform: scale(0.94);
    color: oklch(0.55 0.16 145);
    pointer-events: none;
  }

  .confirm__done svg { inline-size: 1rem; block-size: 1rem; }

  /* Switch tra stati */
  .confirm[data-state='confirming'] .confirm__primary {
    opacity: 0;
    transform: translateY(-6px);
    pointer-events: none;
  }
  .confirm[data-state='confirming'] .confirm__panel {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .confirm[data-state='done'] .confirm__primary,
  .confirm[data-state='done'] .confirm__panel {
    opacity: 0;
    pointer-events: none;
  }
  .confirm[data-state='done'] .confirm__done {
    opacity: 1;
    transform: scale(1);
  }

  /* Focus state coerente sul bottone visibile */
  .confirm__primary:focus-visible,
  .confirm__confirm:focus-visible,
  .confirm__cancel:focus-visible {
    outline: none;
    box-shadow: var(--halo-focus);
    border-radius: var(--radius-pill);
  }
</style>

<script>
  type State = 'idle' | 'confirming' | 'done';

  function bind() {
    document.querySelectorAll<HTMLElement>('.confirm').forEach((host) => {
      if (host.dataset.confirmBound === 'true') return;
      host.dataset.confirmBound = 'true';

      let timer: number | null = null;

      const setState = (s: State) => {
        host.dataset.state = s;
        if (timer != null) {
          clearTimeout(timer);
          timer = null;
        }
        if (s === 'confirming') {
          // auto-cancel dopo 4 s di inattività
          timer = window.setTimeout(() => setState('idle'), 4000);
        }
        if (s === 'done') {
          timer = window.setTimeout(() => setState('idle'), 1400);
        }
      };

      host.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const action = target.closest('[data-action]')?.getAttribute('data-action');
        if (!action) return;

        if (action === 'ask') setState('confirming');
        else if (action === 'cancel') setState('idle');
        else if (action === 'confirm') setState('done');
      });
    });
  }

  document.addEventListener('astro:page-load', bind);
</script>
