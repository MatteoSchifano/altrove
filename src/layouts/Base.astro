---
/* ─────────────────────────────────────────────────────────────
   Altrove · Base.astro — il guscio HTML.

   Responsabilità
   - Carica fonts variabili (Geist + Geist Mono)
   - Imposta meta + lang per l'i18n
   - Inizializza il tema senza flash (FART: flash of incorrect theme)
   - Abilita le View Transitions
   - Esegue il bind dei pattern di motion ad ogni navigazione
   ───────────────────────────────────────────────────────────── */

import '@fontsource-variable/geist/index.css';
import '@fontsource-variable/geist-mono/index.css';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro';
import { t, DEFAULT_LOCALE, type Locale } from '../lib/i18n';

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
}

const { locale = DEFAULT_LOCALE, title, description } = Astro.props;
const finalTitle = title ?? t('site.title', locale);
const finalDescription = description ?? t('site.description', locale);

/* L'autodiscovery RSS preferisce il feed nella stessa lingua della
   pagina. L'altro feed va comunque dichiarato (alternate). */
const rssIt = { href: '/rss.xml', title: t('site.title', 'it') };
const rssEn = { href: '/en/rss.xml', title: t('site.title', 'en') };
const primaryRss = locale === 'en' ? rssEn : rssIt;
const secondaryRss = locale === 'en' ? rssIt : rssEn;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={finalDescription} />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={primaryRss.title} href={primaryRss.href} />
    <link rel="alternate" type="application/rss+xml" title={secondaryRss.title} href={secondaryRss.href} />

    <title>{finalTitle}</title>

    {/* Theme bootstrap — eseguito INLINE prima del paint per evitare flash.
        Legge la preferenza salvata, fallback al sistema. */}
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem('altrove-theme');
          if (saved === 'light' || saved === 'dark') {
            document.documentElement.dataset.theme = saved;
          }
        } catch (_) {
          /* localStorage può essere bloccato — pazienza, useremo il sistema */
        }
      })();
    </script>

    <ClientRouter />
  </head>

  <body>
    <slot />

    {/* Bind dei pattern di motion. Ri-eseguito ad ogni navigazione
        client-side (View Transitions emette `astro:page-load`). */}
    <script>
      import { bindMotionAttributes } from '../lib/motion.ts';

      let cleanup: (() => void) | null = null;

      const init = () => {
        cleanup?.();
        cleanup = bindMotionAttributes();
      };

      document.addEventListener('astro:page-load', init);
      document.addEventListener('astro:before-swap', () => cleanup?.());
    </script>

    <Analytics />
  </body>
</html>
